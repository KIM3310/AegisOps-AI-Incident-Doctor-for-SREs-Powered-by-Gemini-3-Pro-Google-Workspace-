# LLM provider:
# - auto   : OpenAI when OPENAI_API_KEY is set, then Gemini when GEMINI_API_KEY is set, otherwise demo mode
# - demo   : demo mode
# - gemini : Gemini mode (falls back to demo if key missing)
# - ollama : local offline Ollama mode
# - openai : OpenAI mode (falls back to demo if key missing)
LLM_PROVIDER=auto

# OpenAI (used when LLM_PROVIDER=openai or auto with OPENAI_API_KEY set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_TIMEOUT_MS=45000
OPENAI_RETRY_MAX_ATTEMPTS=3
OPENAI_RETRY_BASE_DELAY_MS=400

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL_ANALYZE=gemini-3.1-pro-preview
GEMINI_MODEL_ANALYZE_FALLBACK=gemini-2.5-flash
GEMINI_MODEL_TTS=gemini-2.5-flash-preview-tts

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_ANALYZE=llama3.1:8b
OLLAMA_MODEL_FOLLOWUP=llama3.1:8b

# API security/runtime
API_KEY_SETTINGS_TOKEN=
ALLOW_REMOTE_API_KEY_SETTINGS=false
HOST=127.0.0.1
PORT=8787
TRUST_PROXY=false

# Gemini request controls
GEMINI_TIMEOUT_MS=45000
GEMINI_RETRY_MAX_ATTEMPTS=3
GEMINI_RETRY_BASE_DELAY_MS=400
GROUNDING_DEFAULT=false

# Request limits
REQUEST_BODY_LIMIT_MB=25
MAX_IMAGES=8
MAX_IMAGE_BYTES=5000000
MAX_LOG_CHARS=50000
MAX_QUESTION_CHARS=4000
MAX_TTS_CHARS=5000

# Cache
ANALYZE_CACHE_TTL_SEC=300
ANALYZE_CACHE_MAX_ENTRIES=200

# ── AWS Integration (optional, env-var gated) ──
# All AWS features activate when AWS_ACCESS_KEY_ID is set.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=kim3310-505875808207-aegisops-reports
AWS_SQS_QUEUE_URL=
AWS_CLOUDWATCH_LOG_GROUP=aegisops
AWS_CLOUDWATCH_LOG_STREAM=api

# ── GCP Integration (optional, env-var gated) ──
# All GCP features activate when GOOGLE_APPLICATION_CREDENTIALS is set.
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GCP_STORAGE_BUCKET=aegisops-reports
GCP_BIGQUERY_DATASET=aegisops_analytics

# ── Datadog Monitoring (optional, env-var gated) ──
# All Datadog features activate when DD_API_KEY is set.
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com
DD_SERVICE=aegisops
DD_ENV=production

# Frontend optional vars
VITE_GOOGLE_CLIENT_ID=
VITE_FORMSPREE_ENDPOINT=
VITE_DISQUS_SHORTNAME=
VITE_DISQUS_IDENTIFIER=aegisops-community
VITE_GISCUS_REPO=
VITE_GISCUS_REPO_ID=
VITE_GISCUS_CATEGORY=
VITE_GISCUS_CATEGORY_ID=
VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_SLOT=1234567890
VITE_TM_MODEL_URL=
